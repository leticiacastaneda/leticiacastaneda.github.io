  <footer>
    <div class="pie-inner">
      <span>© 2026 Leticia Castañeda</span>
      <a href="https://open.spotify.com/show/7cbsrFc60LjgTQuLOnTyHB" target="_blank" rel="noopener">Kilometraje Corporativo · Podcast</a>
    </div>
  </footer>

  <script>
    const datos = {
      "timeline-1": [
        { titulo: "An inherited program with no context", detalle: "In my first quarter, I was handed a presentation to 'update' with no further explanation. Only when I opened it did I discover it was an internal instructor training program. I updated it, facilitated it at a site, and without anyone formally explaining it to me, the program became mine to manage." },
        { titulo: "Investigating the origin and diagnosing the situation", detalle: "When my manager started asking me about metrics and award events I didn't know existed, I began digging. I found a procedure documenting more than twenty people who had managed the program over the years. It existed, but no one was running it with any clarity: the SME figure had disappeared and the L&D area had lost active involvement." },
        { titulo: "Rebuilding the process and roles", detalle: "I updated the documented process, redefined roles (instructors, area managers, L&D), and clarified scopes and profiles. The program went from something nobody understood to having traceability, metrics, and a formal record of internal courses delivered." },
        { titulo: "Leadership sponsorship and points system", detalle: "I reactivated the compensation system with updated scales and a negotiated budget. I secured active sponsorship from area managers — without that, no instructor program survives. Over four years: more than a hundred colleagues trained as internal instructors, across all areas of the operation." },
        { titulo: "English Conversation Club: my own initiative", detalle: "I proposed and designed the English Conversation Club to support colleagues who were too shy to speak English in a multinational company. I developed the methodology, the diagnostic to select participants and potential instructors, and the train-the-trainers for the club's facilitators. It worked so well it was officially documented as an extension of the internal instructor program procedure." }
      ],
      "timeline-2": [
        { titulo: "Diagnosis: instructors with no real training", detalle: "There were internal instructors, but their courses lacked structure and planning. Both employees and managers were asking for the same thing: more practice, less theory. That diagnosis was my starting point." },
        { titulo: "Design from scratch: pedagogical foundations and practice", detalle: "I taught from the basics of the teaching-learning process through educational planning criteria and group management. Twenty hours of training plus the time each instructor spent implementing their own course, with group feedback as the central learning tool." },
        { titulo: "Two generations trained", detalle: "The first two cohorts — around forty people — came out well prepared. One instructor shared that she had developed the ability to tell when a course is well planned and when it isn't. That's applied metacognition: the most sophisticated outcome a trainer development program can achieve." },
        { titulo: "Operations asks to compress to 4 hours", detalle: "Internal restructuring and tighter schedules led management to request reducing the program to four hours for four simultaneous groups. Four hours don't train anyone — another solution was needed." },
        { titulo: "Redesign with Flipped Classroom", detalle: "Instead of giving in, I redesigned using Flipped Classroom methodology: theory assigned through LinkedIn Learning (licenses already paid for and underused), team work before each session, and in-person time dedicated exclusively to practice and group feedback. This new format reached 40 participants in the final version of the program." }
      ]
    };

    function construirTimeline(contenedorId, pasos) {
      const cont = document.getElementById(contenedorId);
      pasos.forEach(function(p, i) {
        const esUltimo = i === pasos.length - 1;
        const item = document.createElement("div");
        item.className = "paso-item";
        item.style.marginBottom = esUltimo ? "0" : "16px";
        item.innerHTML =
          (!esUltimo ? '<div class="paso-conector" style="bottom:-16px;"></div>' : '') +
          '<div class="paso-punto"></div>' +
          '<button class="paso-boton" data-cont="' + contenedorId + '" data-i="' + i + '">' +
            '<span class="paso-titulo">' + p.titulo + '</span>' +
            '<span class="paso-accion"><span class="palabra-accion" data-cont="' + contenedorId + '" data-i="' + i + '">see more</span><span class="paso-flecha flecha-accion" data-cont="' + contenedorId + '" data-i="' + i + '">↓</span></span>' +
          '</button>' +
          '<div class="paso-panel panel-detalle" data-cont="' + contenedorId + '" data-i="' + i + '"><p>' + p.detalle + '</p></div>';
        cont.appendChild(item);
      });
    }

    function alternarPaso(contId, i) {
      const panel = document.querySelector('.panel-detalle[data-cont="' + contId + '"][data-i="' + i + '"]');
      const flecha = document.querySelector('.flecha-accion[data-cont="' + contId + '"][data-i="' + i + '"]');
      const palabra = document.querySelector('.palabra-accion[data-cont="' + contId + '"][data-i="' + i + '"]');
      const abierto = panel.style.maxHeight && panel.style.maxHeight !== "0px";
      if (abierto) { panel.style.maxHeight = "0px"; flecha.style.transform = "rotate(0deg)"; palabra.textContent = "see more"; }
      else { panel.style.maxHeight = panel.scrollHeight + 40 + "px"; flecha.style.transform = "rotate(180deg)"; palabra.textContent = "see less"; }
    }

    construirTimeline("timeline-1", datos["timeline-1"]);
    construirTimeline("timeline-2", datos["timeline-2"]);
    document.querySelectorAll(".paso-boton").forEach(function(btn) { btn.addEventListener("click", function() { alternarPaso(this.dataset.cont, this.dataset.i); }); });
    setTimeout(function() { alternarPaso("timeline-1", "0"); alternarPaso("timeline-2", "0"); }, 50);
  </script>
</body>
