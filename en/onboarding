  <title>Onboarding — Leticia Castañeda</title>
  <meta name="description" content="Case study: onboarding in global manufacturing and the tequila industry — from a scalable system to a tailored experience.">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400&family=Work+Sans:wght@400;500&display=swap" rel="stylesheet">
